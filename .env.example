# Cloudways Manager – environment variables
#
# Copy this file to .env and fill in your credentials.
# Never commit the .env file to source control.

# Your Cloudways account e-mail address
CLOUDWAYS_EMAIL=your@email.com

# API key from Cloudways → Account → API (https://platform.cloudways.com/api)
CLOUDWAYS_API_KEY=your_api_key_here
